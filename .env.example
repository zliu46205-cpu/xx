# Frontend env for Vite
# Local development:
VITE_XUANXUE_API_BASE=http://127.0.0.1:8787

# Production example:
# VITE_XUANXUE_API_BASE=https://api.your-domain.com

# Backend env
XUANXUE_API_PORT=8787

# Optional DeepSeek report generation
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Auth and admin
SESSION_SECRET=change-to-a-long-random-secret-at-least-24-chars
ADMIN_ACCOUNT=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_CODE=change-me

# Public beta
FREE_PUBLIC_BETA=true

# Payment: currently paused in the frontend. WeChat and Alipay settings are kept for later use.
# Personal QR codes cannot automatically notify the site. For true auto-granting,
# connect a WeChat Pay / Alipay merchant callback or an aggregate payment webhook.
DEFAULT_PAYMENT_PROVIDER=wechat
PAYMENT_RECEIVER_NAME=your-name
PAYMENT_WECHAT_QR_URL=/assets/pay-wechat.jpg
PAYMENT_ALIPAY_QR_URL=/assets/pay-alipay.jpg
PAYMENT_MANUAL_NOTE=付款时建议备注订单号。接入正式商户回调后，系统会自动确认到账并发放权益。
PAYMENT_WEBHOOK_SECRET=change-to-a-long-payment-webhook-secret
