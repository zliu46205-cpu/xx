# Frontend env for Vite
# Local development:
VITE_XUANXUE_API_BASE=http://127.0.0.1:8787

# Production example:
# VITE_XUANXUE_API_BASE=https://api.your-domain.com

# Backend env
XUANXUE_API_PORT=8787

# Optional DeepSeek report generation
# If empty, the site uses the built-in rule engine fallback.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Auth and admin
SESSION_SECRET=change-to-a-long-random-secret-at-least-24-chars
ADMIN_ACCOUNT=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_CODE=change-me
ENABLE_MOCK_PAYMENTS=true
PAYMENT_WEBHOOK_SECRET=change-to-a-long-payment-webhook-secret

